{
  "name": "integrity-gate",
  "version": "1.0.0",
  "description": "Output verification system for Claude Code. 26 rules + 6 patterns prevent AI fabrications, contradictions, and unfounded conclusions.",
  "author": "danolez1",
  "license": "MIT",
  "repository": "danolez1/claude-integrity-gate",
  "keywords": [
    "verification",
    "integrity",
    "safety",
    "output-validation",
    "hooks",
    "evidence"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-gate.js"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-stop.js"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-prompt-reinject.js"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-posttool.js"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-notification.js"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/output-integrity-subagent.js"
          }
        ]
      }
    ]
  },
  "skills": [
    "plugins/integrity-gate/skills/integrity-gate"
  ]
}
